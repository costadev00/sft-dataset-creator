{
  "name": "wiki-brazil-smoke",
  "language": "pt-BR",
  "profile": null,
  "source": {
    "plugin": "huggingface",
    "params": {
      "dataset": "costadev00/wiki-brazil",
      "subset": "default",
      "split": "train",
      "streaming": true,
      "cache_dir": "/scratch/sft-dataset-creator/wiki-brazil/cache"
    },
    "field_map": {
      "id": "__row_index__",
      "text": "text",
      "title": "title"
    }
  },
  "selection": {
    "count": null,
    "fraction": 1.0,
    "seed": 42,
    "strata": [],
    "filters": {}
  },
  "target": {
    "examples": 1617,
    "per_document": {"minimum": 1, "maximum": 1},
    "reserve_fraction": 0.0,
    "same_document_attempts": 1,
    "max_attempts_per_slot": 1,
    "max_total_attempt_multiplier": 1.0,
    "chunk_size_characters": 8000,
    "chunk_overlap_characters": 400
  },
  "composition": {
    "tasks": {
      "counts": null,
      "weights": {
        "closed_qa": 0.4,
        "summarization": 0.2,
        "information_extraction": 0.2,
        "concept_explanation": 0.2
      }
    },
    "difficulties": {
      "counts": null,
      "weights": {"easy": 0.25, "medium": 0.5, "hard": 0.25}
    },
    "grounding_required": true
  },
  "generation": {
    "plugin": "vllm_local",
    "params": {
      "tensor_parallel_size": 4,
      "gpu_memory_utilization": 0.92,
      "dtype": "bfloat16",
      "enable_thinking": false,
      "max_num_seqs": 16,
      "max_num_batched_tokens": 16384,
      "enable_chunked_prefill": true,
      "enable_prefix_caching": true
    },
    "model": "google/gemma-4-26B-A4B-it",
    "model_revision": null,
    "context_window": 65536,
    "max_input_tokens": 53248,
    "max_output_tokens": 4096,
    "temperature": 0.1,
    "batching": {
      "mode": "async",
      "max_inflight_requests": 32,
      "queue_capacity": 64,
      "preparation_batch_size": 128,
      "request_timeout_seconds": 900.0
    }
  },
  "evaluation": {
    "plugin": "composite",
    "deterministic": true,
    "llm": null,
    "routing": {
      "audit_fraction": 0.0,
      "judge_hard_tasks": false,
      "judge_truncated_context": false,
      "judge_high_risk": false,
      "judge_weak_grounding": false
    },
    "acceptance": {"overall_score": 4.0, "grounding_score": 4.0}
  },
  "output": {
    "formats": ["messages", "prompt_completion", "alpaca"],
    "containers": ["jsonl"],
    "splits": {"train": 0.9, "validation": 0.05, "test": 0.05}
  },
  "runtime": {
    "run_root": "/scratch/sft-dataset-creator/wiki-brazil/runs",
    "cache_dir": "/scratch/sft-dataset-creator/wiki-brazil/cache",
    "store_model_io": true,
    "fail_on_partial": false
  },
  "publish": {"repo_id": null, "private": true, "token_env": "HF_TOKEN"}
}
